PORT=4000
NODE_ENV=development

# CORS: origin del frontend (Vite)
FRONTEND_ORIGIN=http://localhost:5173

# Base URL pública del backend (para armar URLs en logs / webhooks)
BACKEND_BASE_URL=http://localhost:4000

# Mercado Pago
MP_PUBLIC_KEY=APP_USR-47ff06cd-6fd8-4f9e-bdca-75d1d3cfa319
MP_ACCESS_TOKEN=APP_USR-137663278645028-030615-2c5c0232b4ea0949ca9f5ea38a4da3a9-3248032087

# Si tu webhook necesita ser público (ngrok / deploy), poné la URL completa:
# Ej: https://xxxx.ngrok-free.app/webhook/mercadopago
MP_WEBHOOK_URL=

# Google Sheets (actualización de stock)
GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_SHEET_ID
# Rango que incluya fila de headers. Ej: Productos!A1:Z1000
GOOGLE_SHEETS_RANGE=Productos!A1:Z1000

# Autenticación Google (Service Account)
# Opción A: ruta a JSON (recomendado)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# Opción B: variables separadas
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
