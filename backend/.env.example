PORT=4000
NODE_ENV=development

# CORS: origin del frontend (Vite)
FRONTEND_ORIGIN=http://localhost:5173

# Base URL pública del backend (para armar URLs en logs / webhooks)
BACKEND_BASE_URL=http://localhost:4000

# Mercado Pago
MP_PUBLIC_KEY=YOUR_PUBLIC_KEY
MP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# Si tu webhook necesita ser público (ngrok / deploy), poné la URL completa:
# Ej: https://xxxx.ngrok-free.app/webhook/mercadopago
MP_WEBHOOK_URL=

# --- Opción A: Google Apps Script (sin Google Cloud / sin service account) ---
# Guía: ../../docs/APPS_SCRIPT_SHEETS.md
# Pegá la URL de "Implementar" → Aplicación web (termina en /exec)
GOOGLE_APPS_SCRIPT_URL=
# Misma clave que SECRET en el script (Code.gs)
GOOGLE_APPS_SCRIPT_SECRET=

# --- Opción B: Google Sheets API (service account) ---
# Si usás Opción A, podés dejar vacíos spreadsheet + rango + auth de abajo.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=ValidacionSTOCK!A1:Z1000
GOOGLE_EGRESOS_SHEET_NAME=Egresos

GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
